# Application
APP_ENV=dev
APP_PORT=8080

# MongoDB (local)
DB_ENGINE=mongodb
DB_HOST=localhost
DB_PORT=27017
DB_NAME=resource_db
DB_USERNAME=app
DB_PASSWORD=app_pw

MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DBNAME=resource_db
MONGODB_USERNAME=app
MONGODB_PASSWORD=app_pw
MONGODB_URI=mongodb://localhost:27017/resource_db
MONGODB_TLS=false

# JWT (same keys used by go-auth-service)
JWT_ACCESS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_ACCESS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_KID=auth-service-1
JWT_ISSUER=auth-service
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Cookies
AUTH_ACCESS_COOKIE_NAME=access_token
AUTH_REFRESH_COOKIE_NAME=refresh_token
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_PATH=/

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Valkey (local)
VALKEY_ADDR=localhost:6379
VALKEY_USE_TLS=false
VALKEY_PASSWORD=
VALKEY_DB=0
VALKEY_PREFIX=auth:refresh

# Telemetry (optional)
OTEL_SERVICE_NAME=resource-service
OTEL_SERVICE_VERSION=dev
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_EXPORTER_OTLP_TIMEOUT=10000
OTEL_METRIC_EXPORT_INTERVAL=15000
